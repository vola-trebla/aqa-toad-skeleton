{
  "name": "aqa-toad-skeleton",
  "version": "1.0.0",
  "description": "Ultimate SDET Framework Skeleton | Playwright + TypeScript + Zod",
  "main": "index.js",
  "scripts": {
    "test": "npx playwright test",
    "test:smoke": "npx playwright test --project=smoke",
    "test:critical": "npx playwright test --project=critical",
    "test:api": "npx playwright test --project=api",
    "test:regression": "npx playwright test --project=regression-chrome",
    "lint": "eslint . --ext .ts",
    "typecheck": "tsc --noEmit"
  },
  "keywords": [
    "playwright",
    "typescript",
    "zod",
    "sdet",
    "automation",
    "testing"
  ],
  "author": "",
  "license": "ISC",
  "devDependencies": {
    "@playwright/test": "^1.44.0",
    "@typescript-eslint/eslint-plugin": "^7.8.0",
    "@typescript-eslint/parser": "^7.8.0",
    "@types/node": "^20.12.7",
    "allure-playwright": "^3.0.0-beta.2",
    "eslint": "^8.57.0",
    "typescript": "^5.4.5",
    "zod": "^3.23.4",
    "dotenv": "^16.4.5"
  }
}
