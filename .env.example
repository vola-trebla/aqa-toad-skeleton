# --- Target environment ---
# For the public OrangeHRM demo, leave defaults. Set credentials explicitly for any other env.
BASE_URL=https://opensource-demo.orangehrmlive.com
API_URL=https://opensource-demo.orangehrmlive.com

# --- Credentials ---
# REQUIRED for any non-demo BASE_URL. Optional for the demo (safe defaults applied).
ADMIN_USERNAME=Admin
ADMIN_PASSWORD=admin123

# --- Optional ---
GITHUB_TOKEN=<YOUR_PERSONAL_ACCESS_TOKEN>
ENV=staging
CI=false
# Set a real Slack webhook URL to enable notifications
SLACK_WEBHOOK=
