# --- Application Configuration ---
# The base URL of the application under test
BASE_URL=https://your-app-url.com

# Optional: Separate URL for API tests if different from BASE_URL
# API_URL=https://api.your-app-url.com

# --- Credentials ---
# Use these for your test account
ADMIN_USERNAME=admin
ADMIN_PASSWORD=password123

# --- Environment ---
# local, staging, production (defaults to staging)
ENV=staging

# --- Reporting ---
# Optional: Slack Webhook URL for notifications
# SLACK_WEBHOOK=https://hooks.slack.com/services/YOUR/WEBHOOK/URL
